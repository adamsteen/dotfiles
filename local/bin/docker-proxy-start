#!/bin/bash
# Expose root-owned /var/run/docker.sock as a world-writable user socket via
# socat, so docker / devcontainer work without sudo on RMT Linux sessions.
set -euo pipefail

SOCKET=/tmp/docker-user.sock

if [ -S "$SOCKET" ]; then
  echo "Docker proxy already running"
  exit 0
fi

# Resolve socat against the user's PATH and pass the absolute path to sudo,
# since sudo's secure_path on Debian drops /home/linuxbrew/.linuxbrew/bin
# (where brew installs socat) — so plain `sudo socat` would fail with
# "command not found" even when socat is installed.
SOCAT="$(command -v socat || true)"
if [ -z "$SOCAT" ]; then
  echo "docker-proxy-start: socat not found on PATH" >&2
  echo "  install with: brew install socat   (or: sudo apt install socat)" >&2
  exit 1
fi

# setsid -f: run socat in its own session, detached from the controlling
# tty, so closing the launching shell doesn't SIGHUP it. Redirects close
# the inherited tty fds so the parent can exit cleanly. setsid -f forks
# and returns immediately — no `&` needed.
sudo setsid -f "$SOCAT" UNIX-LISTEN:${SOCKET},fork,mode=777 \
  UNIX-CONNECT:/var/run/docker.sock \
  </dev/null >/dev/null 2>&1

# Poll briefly for the socket to appear so we don't report success before
# socat has actually bound. socat normally binds in <100ms; cap at ~2s.
# If socat dies before binding we just time out and report failure below.
for _ in $(seq 1 20); do
  [ -S "$SOCKET" ] && break
  sleep 0.1
done

if [ -S "$SOCKET" ]; then
  echo "Docker proxy started"
else
  echo "docker-proxy-start: socat exited before $SOCKET appeared" >&2
  exit 1
fi
